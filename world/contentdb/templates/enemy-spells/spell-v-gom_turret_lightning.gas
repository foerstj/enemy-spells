[t:template,n:base_spell_gom_turret_lightning_player]
{
	specializes = base_spell_enemy_spells_nature_magic;

	doc = "spell gom turret lightning (player)";
	[common]
	{
		screen_name = "Lightning Turret";
		description = "Spell of Gom.";
		membership = spells_nature, spells_electric;
	}
	[gui]
	{
		active_icon		= b_gui_ig_i_ic_sp_es-v-gom_turret_lightning;
		inventory_icon	= b_gui_ig_i_ic_sp_es-v-gom_turret_lightning-inv;
	}
	[magic]
	{
		cast_range = 14;
		cast_reload_delay = 3;
	}

	[aspect]
	{
		gold_value = 170000;
	}
	[magic]
	{
		required_level = 68;
		max_level = 88;

		mana_cost_modifier = ((#magic*2) * 1.0) * 2.0;

		attack_damage_modifier_min = (((#magic*3) * 1.0) * 0.222) * 0.9;
		attack_damage_modifier_max = (((#magic*3) * 1.0) * 0.222) * 1.1;

		cast_sub_animation = 1;
	}
}

[t:template,n:spell_gom_turret_lightning_player] { specializes = base_spell_gom_turret_lightning_player_impl; }
